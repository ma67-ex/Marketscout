# Market Scout environment.
#
# These run live with NO keys and need nothing below:
# - Nominatim (OpenStreetMap) for address -> coordinates
# - Overpass (OpenStreetMap) for nearby businesses
# The app produces real, worldwide results out of the box on these alone.
#
# Everything below is OPTIONAL and only adds richer data. Copy this file to
# ".env.local" and fill in whatever you have.

# --- Yelp Fusion (real ratings + reviews) [OPTIONAL, FREE] ----------------
# Get a free key at https://www.yelp.com/developers/v3/manage_app
# When set, places come from Yelp (real ratings, review counts, and review
# excerpts that power the "what people want" analysis) instead of OSM. Falls
# back to OSM automatically where Yelp has no coverage.
YELP_API_KEY=
# How many of the busiest businesses to pull review text for (default 6):
# MARKET_SCOUT_YELP_REVIEWS=6

# --- Reddit (local discussion) [OPTIONAL] ---------------------------------
# NOTE: Reddit's keyless public search now returns 403, so real Reddit data
# requires a free "script" app from https://www.reddit.com/prefs/apps
# (client id + secret below). Without it, the Reddit signal is simply skipped.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=market-scout/0.1 by u/yourusername

# --- Anthropic (AI-written synthesis) [OPTIONAL] ---------------------------
# Leave blank to use the built-in template synthesis (still real data).
ANTHROPIC_API_KEY=

# --- Optional tuning -------------------------------------------------------
# Force fully offline sample data everywhere (no network calls at all):
# MARKET_SCOUT_FORCE_MOCK=1
# MARKET_SCOUT_RADIUS_METERS=2500
# MARKET_SCOUT_MAX_PLACES=40
# MARKET_SCOUT_MAX_REDDIT=25
# MARKET_SCOUT_AI_MODEL=claude-sonnet-5

# --- Rate limiting (POST /api/analyze) [OPTIONAL] --------------------------
# Keyless, in-memory, per-IP fixed-window limiter -- no external service.
# Max requests per window per client IP (default 20):
# MARKET_SCOUT_RATE_LIMIT=20
# Window length in milliseconds (default 60000 = 1 minute):
# MARKET_SCOUT_RATE_WINDOW_MS=60000
# Set MARKET_SCOUT_RATE_LIMIT=0 to disable rate limiting (local dev/testing).
